<% layout("/layouts/boilerplate.ejs") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <h3>Edit your Listing</h3>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT"  class="needs-validation" novalidate enctype="multipart/form-data">
        <div class="mb-3">
            <lable for="title" class="form-lable">Title</lable>
            <input name= "listing[title]" value="<%=listing.title%>" type="text" class="form-control" required>
            <div class="valid-feedback">
                Title looks good!
            </div>
            <div class="invalid-feedback">
                Please give title.
            </div>
        </div>
        <div class="mb-3">
            <lable for="description" class="form-lable">Description</lable>
            <textarea name= "listing[description]" type="text" class="form-control" required> <%=listing.description%> </textarea>
            <div class="valid-feedback">
                Description looks good!
            </div>
            <div class="invalid-feedback">
                Please give a short description.
            </div>
        </div>
        <div class="mb-3">
           <div>Original listing image <br><img src="<%=listing.image.url%>" style="width:300px;height :auto;border-radius: 8px;"></div><br>
            <lable for="image" class="form-lable">Upload Image url</lable>
            <input name= "image"  type="file" class="form-control" >
        </div>
         <!-- <div class="mb-3">
            <lable for="image" class="form-lable">Image filename</lable>
            <input name= "listing[image][filename]" value="<%=listing.image.filename%>"  type="text" class="form-control" >
        </div> -->
        <!-- Category -->
        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" id="category" class="form-control" required>
                <option value="trending" <%= listing.category ==="trending" ? "selected" : "" %>>Trending</option>
                <option value="room" <%= listing.category === "room" ? "selected" : "" %>>Room</option>
                <option value="iconic_cities" <%= listing.category === "iconic_cities" ? "selected" : "" %>>Iconic Cities</option>
                <option value="mountain_cities" <%= listing.category === "mountain_cities" ? "selected" : "" %>>Mountain Cities</option>
                <option value="mountains" <%= listing.category === "mountains" ? "selected" : "" %>>Mountains</option>
                <option value="castles" <%= listing.category === "castles" ? "selected" : "" %>>Castles</option>
                <option value="amazing_pools" <%= listing.category === "amazing_pools" ? "selected" : "" %>>Amazing Pools</option>
                <option value="campaing" <%= listing.category === "campaing" ? "selected" : "" %>>Campaing</option>
                <option value="farms" <%= listing.category === "farms" ? "selected" : "" %>>Farms</option>
                <option value="arctic" <%= listing.category === "arctic" ? "selected" : "" %>>Arctic</option>
            </select>
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <lable for="price" class="form-lable">Price</lable>
                <input name= "listing[price]" value="<%=listing.price%>"class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter price.
                </div>
            </div>
            <div class="mb-3 col-md-8">
                <lable for="country" class="form-lable">Country</lable>
                <input name= "listing[country]" value="<%=listing.country%>" type="text" class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please specify country.
                </div>
            </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-lable">Location</lable>
            <input name= "listing[location]" value="<%=listing.location%>" type="text" class="form-control" required>
            <div class="valid-feedback">
                    Looks good!
            </div>
            <div class="invalid-feedback">
                Please specify location.
            </div>
        </div>
        <button class="btn btn-dark edit-btn">Edit</button><br><br><br>
    </form>
</div>
</div>
