<% layout("/layouts/boilerplate.ejs") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <h3>Create new Listing</h3>
    <form method="POST" action="/listings" class="needs-validation" novalidate enctype="multipart/form-data">
        <div class="mb-3">
            <lable for="title" class="form-lable">Title</lable>
            <input name= "listing[title]" placeholder="enter title" type="text" class="form-control" required> 
            <div class="valid-feedback">
                Title looks good!
            </div>
            <div class="invalid-feedback">
                Please give title.
            </div>
        </div>
        <div class="mb-3">
            <lable for="description" class="form-lable">Description</lable>
            <textarea name= "listing[description]" type="text" class="form-control" required></textarea>
            <div class="valid-feedback">
                Description looks good!
            </div>
            <div class="invalid-feedback">
                Please give a short description.
            </div>
        </div>
        
        <!-- <div class="mb-3">
            <lable for="image" class="form-lable">Image Link</lable>
           <input name="listing[image][url]" placeholder="enter image URL" type="text" class="form-control" >
        </div>
        <div class="mb-3">
            <lable for="image" class="form-lable">Image Link</lable>
           <input name="listing[image][filename]" placeholder="enter image path" type="text" class="form-control" >
        </div> -->



        <div class="mb-3">
            <lable for="image" class="form-lable">Upload Image</lable>
           <input name="image" placeholder="upload image" type="file" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">Category</label>
        <select name="listing[category]" class="form-control">
            <option value="trending">Trending</option>
            <option value="room">Room</option>
            <option value="iconic">Iconic Cities</option>
            <option value="mountains">Mountains</option>
            <option value="castles">Castles</option>
            <option value="pools">Amazing Pools</option>
            <option value="camping">Camping</option>
            <option value="farms">Farms</option>
            <option value="arctic">Arctic</option>
        </select>


        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <lable for="price" class="form-lable">Price</lable>
                <input name= "listing[price]"  placeholder="enter price"  type="number" class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter price.
                </div>
            </div>
            <div class="mb-3 col-md-8">
                <lable for="country" class="form-lable">Country</lable>
                <input name= "listing[country]" placeholder="enter country" type="text" class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                </div>
                <div class="invalid-feedback">
                    Please specify country.
                </div>
            </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-lable">Location</lable>
            <input name= "listing[location]" placeholder="enter location" type="text" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
            </div>
            <div class="invalid-feedback">
                Please specify location.
            </div>
        </div>       
        <button class="btn btn-dark add-btn">Add</button><br><br><br>
    </form>
</div>
</div>
